{
  "name": "@maya/web",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "build": "mkdir -p dist/public && bun build --target=bun --production --minify --outdir dist ./index.ts && cp -R public/. dist/public/",
    "dev": "bun --watch index.ts",
    "check": "oxlint --config ./.oxlintrc.json --fix . && oxfmt --config ./.oxfmtrc.jsonc .",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "start": "NODE_ENV=production bun dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
