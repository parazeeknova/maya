{
  "name": "@maya/web",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "build": "mkdir -p dist/public && bun build --target=bun --production --minify --sourcemap --external sharp --outdir dist ./index.ts && cp -R public/. dist/public/",
    "dev": "bun --watch index.ts",
    "check": "oxlint --config ./.oxlintrc.json --fix . && oxfmt --config ./.oxfmtrc.jsonc .",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "start": "NODE_ENV=production bun dist/index.js",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun test && playwright test"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2"
  }
}
