MAYA_SERVE_HOST=127.0.0.1
MAYA_SERVE_PORT=8765

MAYA_ENROLLMENT_DIR=/app/data/enrolled
MAYA_ENROLLMENT_SYNC_ENABLED=false
MAYA_ENROLLMENT_SYNC_BASE_URL=https://r2-maya.singularityworks.xyz

MAYA_MODEL_PACK=buffalo_l
MAYA_MODEL_ROOT=/app/.insightface

MAYA_DETECTOR_WIDTH=320
MAYA_DETECTOR_HEIGHT=320

MAYA_MATCH_THRESHOLD=0.55
MAYA_MATCH_TOP_K=5
MAYA_MATCH_MARGIN_THRESHOLD=0.04
MAYA_MIN_DETECTION_CONFIDENCE=0.5
MAYA_RELOAD_INTERVAL_SECONDS=2.0

MAYA_TRACKING_ENABLED=true
MAYA_TRACKER_ACTIVATION_THRESHOLD=0.35
MAYA_TRACKER_MATCHING_THRESHOLD=0.8
MAYA_TRACKER_LOST_BUFFER=10
MAYA_TRACKER_MINIMUM_CONSECUTIVE_FRAMES=1
MAYA_TRACKER_FRAME_RATE=6
MAYA_TRACKER_BOX_SMOOTHING_ALPHA=0.58
MAYA_TRACKER_IDENTITY_SWITCH_HITS=2
MAYA_TRACKER_STABLE_CONFIDENCE_FLOOR=0.48
MAYA_TRACKER_TRACK_HOLD_MS=4000
